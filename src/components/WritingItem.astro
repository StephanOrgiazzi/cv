---
interface Props {
  date: string;
  title: string;
  excerpt: string;
  link?: string;
  badges?: string[];
}

const { date, title, excerpt, link = "#", badges = [] } = Astro.props;
---

<a href={link} class="writing-item">
  <div class="writing-date">{date}</div>
  <div class="writing-content">
    {badges.length > 0 && (
      <div class="writing-badges">
        {badges.map((label) => <span class="writing-badge">{label}</span>)}
      </div>
    )}
    <h3 class="writing-title">{title}</h3>
    <p class="writing-excerpt">{excerpt}</p>
  </div>
</a>

<style>
  .writing-item {
    display: flex;
    padding: 3rem 0;
    border-top: 1px solid var(--border-color);
    text-decoration: none;
    color: var(--text-color);
    gap: 4rem;
    position: relative;
    border-left: 3px solid transparent;
    padding-left: 1.25rem;
    margin-left: -1.25rem;
    border-radius: 1.5rem;
    transition:
      background 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      transform 0.25s ease;
  }

  .writing-item:hover .writing-title {
    color: var(--accent-color);
  }

  :global([data-theme='light']) .writing-item:hover {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.46), rgba(238, 242, 248, 0.72));
    border-top-color: rgba(255, 255, 255, 0.2);
    box-shadow:
      0 16px 34px rgba(82, 100, 131, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.84);
    transform: translateY(-1px);
  }
  
  .writing-date {
    flex-shrink: 0;
    width: 140px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.45;
    line-height: 1.5;
    padding-top: 0.6rem;
  }
  
  .writing-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .writing-title {
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
    line-height: 1.1;
    letter-spacing: -0.025em;
    font-weight: 900;
  }

  .writing-badges {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .writing-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.4rem;
    border: 1px solid rgba(var(--text-color-rgb), 0.1);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--bg-color);
    background: var(--text-color);
  }
  
  .writing-excerpt {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 680px;
    line-height: 1.6;
    opacity: 0.9;
  }
  
  @media (max-width: 768px) {
    .writing-item {
      flex-direction: column;
      gap: 1.25rem;
      padding: 2rem 0 2rem 1rem;
      margin-left: -1rem;
    }

    .writing-date {
      width: auto;
      padding-top: 0;
      opacity: 0.4;
    }
    
    .writing-title {
      font-size: 1.9rem;
    }

    .writing-excerpt {
      font-size: 1.05rem;
    }
  }
</style>
